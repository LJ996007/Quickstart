<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Quickstart.Mac.Views.AiWindow"
        Width="620" Height="640" MinWidth="480" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Title="AI 助手"
        Background="#FAFAFA">
  <Grid Margin="12" RowDefinitions="Auto,Auto,*,Auto,2*,Auto">

    <TextBlock Grid.Row="0" Text="AI 助手" FontSize="16" FontWeight="Bold"
               Foreground="#282828" Margin="0,0,0,10"/>

    <!-- 类型 + 动作选择 -->
    <Grid Grid.Row="1" ColumnDefinitions="Auto,160,Auto,*" Margin="0,0,0,8">
      <TextBlock Grid.Column="0" Text="类型" VerticalAlignment="Center" Margin="0,0,6,0"/>
      <ComboBox x:Name="ModeBox" Grid.Column="1" HorizontalAlignment="Stretch"/>
      <TextBlock Grid.Column="2" Text="动作" VerticalAlignment="Center" Margin="12,0,6,0"/>
      <ComboBox x:Name="ActionBox" Grid.Column="3" HorizontalAlignment="Stretch"/>
    </Grid>

    <!-- 输入 -->
    <Grid Grid.Row="2" RowDefinitions="Auto,*">
      <TextBlock Grid.Row="0" Text="输入" Foreground="#505050" Margin="0,0,0,4"/>
      <TextBox x:Name="InputBox" Grid.Row="1" AcceptsReturn="True" TextWrapping="Wrap"
               Watermark="在此输入或粘贴要处理的文本"
               VerticalContentAlignment="Top"/>
    </Grid>

    <TextBlock Grid.Row="3" Text="结果" Foreground="#505050" Margin="0,8,0,4"/>

    <!-- 结果 -->
    <TextBox x:Name="ResultBox" Grid.Row="4" IsReadOnly="True" AcceptsReturn="True"
             TextWrapping="Wrap" VerticalContentAlignment="Top"
             Background="White" Foreground="#202124"/>

    <!-- 状态 + 按钮 -->
    <Grid Grid.Row="5" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
      <TextBlock x:Name="StatusLabel" Grid.Column="0" Text="就绪"
                 Foreground="Gray" VerticalAlignment="Center"/>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
        <Button x:Name="SettingsButton" Content="AI 设置"/>
        <Button x:Name="CopyButton" Content="复制结果"/>
        <Button x:Name="CancelButton" Content="取消" IsEnabled="False"/>
        <Button x:Name="RunButton" Content="运行"/>
      </StackPanel>
    </Grid>

  </Grid>
</Window>
