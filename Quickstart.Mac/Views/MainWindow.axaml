<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:Quickstart.Models;assembly=Quickstart.Core"
        x:Class="Quickstart.Mac.Views.MainWindow"
        x:DataType="models:QuickEntry"
        Width="380" Height="440"
        MinWidth="300" MinHeight="340"
        Title="Quickstart"
        Background="#FAFAFA">
  <Border BorderBrush="#DCDCDC" BorderThickness="1">
    <Grid RowDefinitions="Auto,1,*,Auto">

      <!-- 搜索框 -->
      <TextBox x:Name="SearchBox" Grid.Row="0"
               BorderThickness="0" Background="White"
               Padding="6,4" FontSize="13"
               Watermark="搜索文件夹... (拼音首字母也可)"/>
      <Border Grid.Row="1" Background="#DCDCDC"/>

      <!-- 内容：左标签 | 列表 | 右分组 -->
      <Grid Grid.Row="2" ColumnDefinitions="Auto,1,*,1,Auto">
        <StackPanel x:Name="TabsPanel" Grid.Column="0" Background="#F0F0F0"/>
        <Border Grid.Column="1" Background="#DCDCDC"/>

        <ListBox x:Name="EntryList" Grid.Column="2"
                 Background="White" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="models:QuickEntry">
              <StackPanel Orientation="Vertical" Margin="2,1">
                <TextBlock Text="{Binding Name}" FontSize="13" Foreground="#202124"/>
                <TextBlock Text="{Binding Path}" FontSize="10" Foreground="#9AA0A6"
                           TextTrimming="CharacterEllipsis"/>
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Column="3" Background="#DCDCDC"/>
        <ScrollViewer Grid.Column="4" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
          <StackPanel x:Name="GroupsPanel" Background="#F0F0F0"/>
        </ScrollViewer>
      </Grid>

      <!-- 工具栏 -->
      <Grid Grid.Row="3" ColumnDefinitions="Auto,*" Background="#F5F5F5">
        <StackPanel Orientation="Horizontal" Margin="6,4">
          <Button x:Name="AddButton" Content="＋" Width="28" Height="28"
                  Background="Transparent" BorderThickness="0" Foreground="#4B4B4B"
                  ToolTip.Tip="添加"/>
          <Button x:Name="SettingsButton" Content="⚙" Width="28" Height="28" Margin="4,0,0,0"
                  Background="Transparent" BorderThickness="0" Foreground="#4B4B4B"
                  ToolTip.Tip="设置"/>
        </StackPanel>
        <TextBlock x:Name="CountLabel" Grid.Column="1"
                   HorizontalAlignment="Right" VerticalAlignment="Center"
                   Margin="0,0,10,0" FontSize="11" Foreground="#969696"/>
      </Grid>

    </Grid>
  </Border>
</Window>
