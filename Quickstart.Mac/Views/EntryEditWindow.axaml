<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Quickstart.Mac.Views.EntryEditWindow"
        Width="460" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="编辑条目"
        Background="#FAFAFA">
  <Grid Margin="14" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*,Auto" >

    <TextBlock Grid.Row="0" Grid.Column="0" Text="名称:" VerticalAlignment="Center" Margin="0,0,10,8"/>
    <TextBox x:Name="NameBox" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8"/>

    <TextBlock x:Name="PathLabel" Grid.Row="1" Grid.Column="0" Text="路径:" VerticalAlignment="Center" Margin="0,0,10,8"/>
    <TextBox x:Name="PathBox" Grid.Row="1" Grid.Column="1" Margin="0,0,8,8"/>
    <Button x:Name="BrowseButton" Grid.Row="1" Grid.Column="2" Content="..." Width="44" Margin="0,0,0,8"/>

    <TextBlock Grid.Row="2" Grid.Column="0" Text="类型:" VerticalAlignment="Center" Margin="0,0,10,8"/>
    <ComboBox x:Name="TypeBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8" HorizontalAlignment="Stretch"/>

    <TextBlock Grid.Row="3" Grid.Column="0" Text="分组:" VerticalAlignment="Center" Margin="0,0,10,8"/>
    <AutoCompleteBox x:Name="GroupBox" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8"
                     FilterMode="Contains" Watermark="选择已有分组或输入新分组"
                     HorizontalAlignment="Stretch"/>

    <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal"
                HorizontalAlignment="Right" Margin="0,8,0,0" Spacing="8">
      <Button x:Name="OkButton" Content="确定" Width="88"/>
      <Button x:Name="CancelButton" Content="取消" Width="88"/>
    </StackPanel>

  </Grid>
</Window>
